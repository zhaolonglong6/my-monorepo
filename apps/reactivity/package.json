{
  "name": "@repo/reactivity",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "esbuild index.ts --bundle --outfile=dist/index.js --platform=node --format=esm",
    "dev": "esbuild index.ts --bundle --outfile=dist/index.js --platform=node --format=esm --watch",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@repo/utils": "workspace:*"
  },
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "@repo/tsconfig": "workspace:*",
    "@types/node": "^22.5.4",
    "esbuild": "^0.20.0",
    "typescript": "^5.5.4"
  }
}